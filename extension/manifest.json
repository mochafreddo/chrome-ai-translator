{
  "manifest_version": 3,
  "name": "Chrome AI Translator (Personal)",
  "version": "0.1.0",
  "description": "Personal article translator using OpenAI Responses API.",
  "minimum_chrome_version": "116",

  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": ["https://api.openai.com/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Translate this page"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "options_page": "options.html",

  "commands": {
    "translate-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Translate current tab (article body)"
    }
  }
}
